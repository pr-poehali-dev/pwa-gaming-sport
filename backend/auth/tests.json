{
  "tests": [
    {
      "name": "Register - invalid email",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "email": "bad", "nickname": "xx", "password": "123456"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Некорректный email"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login - wrong credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "nobody@test.com", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный email или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me - no token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    }
  ]
}